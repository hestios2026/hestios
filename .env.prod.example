# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=hestios
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

DATABASE_URL=postgresql://hestios:CHANGE_ME_strong_password_here@postgres:5432/hestios

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_random_64char_hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_user
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=hestios-files

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=erp.hesti-rossmann.de

# ── Admin user (created by seed_prod.py on first deploy) ──────────────────────
ADMIN_EMAIL=admin@hesti-rossmann.de
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ADMIN_NAME=Alexandru Dumitrache

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
